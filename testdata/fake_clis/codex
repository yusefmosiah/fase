#!/bin/sh
set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
last_message=""
mode="run"
session_id="codex-session-123"
prompt=""

emit_text() {
  text="$1"
  printf '%s\n' "{\"type\":\"thread.started\",\"thread_id\":\"$session_id\"}"
  printf '%s\n' "{\"type\":\"item.completed\",\"item\":{\"type\":\"agent_message\",\"text\":\"$text\"}}"
  printf '%s\n' '{"type":"turn.completed","usage":{"input_tokens":1200,"cached_input_tokens":200,"output_tokens":80}}'
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --version|-V)
      printf '%s\n' 'fake-codex 0.0.1'
      exit 0
      ;;
    login)
      shift
      if [ "${1:-}" = "status" ]; then
        printf '%s\n' 'Logged in using ChatGPT'
        exit 0
      fi
      ;;
    resume)
      mode="resume"
      shift
      session_id="${1:-codex-session-123}"
      ;;
    -o)
      shift
      last_message="$1"
      ;;
  esac
  shift
done

if [ "$mode" = "run" ] || [ "$mode" = "resume" ]; then
  prompt="$(cat || true)"
fi

if [ "$mode" = "resume" ]; then
  printf '%s\n' "{\"type\":\"thread.started\",\"thread_id\":\"$session_id\"}"
  if printf '%s' "$prompt" | grep -qi 'writing a cagent debrief'; then
    printf '%s\n' '{"type":"item.completed","item":{"type":"agent_message","text":"# Objective\nExplain the current task state.\n\n# Completed\n- Finished the prior task.\n\n# Current State\nThe repository is in a recoverable state.\n\n# Outstanding Work\n- Review the latest changes.\n\n# Risks\n- The next agent should verify behavior before proceeding.\n\n# Important Files\n/tmp/fake-file.go\n\n# Recommended Next Step\nReview the recent changes and continue from there."}}'
    printf '%s\n' '{"type":"turn.completed","usage":{"input_tokens":700,"cached_input_tokens":100,"output_tokens":120}}'
  else
    printf '%s\n' '{"type":"item.completed","item":{"type":"agent_message","text":"Codex continued the task"}}'
    printf '%s\n' '{"type":"turn.completed","usage":{"input_tokens":600,"cached_input_tokens":50,"output_tokens":40}}'
  fi
elif printf '%s' "$prompt" | grep -qi 'recursive cagent orchestration'; then
  printf '%s\n' "{\"type\":\"thread.started\",\"thread_id\":\"$session_id\"}"
  plan_json="$(printf '%s' 'plan stage' | "$CAGENT_EXECUTABLE" --config "$CAGENT_CONFIG_PATH" --json run --adapter codex --cwd "$PWD" --stdin)"
  plan_job="$(printf '%s' "$plan_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["job"]["job_id"])')"
  "$CAGENT_EXECUTABLE" --config "$CAGENT_CONFIG_PATH" --json status --wait "$plan_job" >/dev/null
  implement_json="$(printf '%s' 'implement stage' | "$CAGENT_EXECUTABLE" --config "$CAGENT_CONFIG_PATH" --json run --adapter codex --cwd "$PWD" --stdin)"
  implement_job="$(printf '%s' "$implement_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["job"]["job_id"])')"
  "$CAGENT_EXECUTABLE" --config "$CAGENT_CONFIG_PATH" --json status --wait "$implement_job" >/dev/null
  verify_json="$(printf '%s' 'verify stage' | "$CAGENT_EXECUTABLE" --config "$CAGENT_CONFIG_PATH" --json run --adapter codex --cwd "$PWD" --stdin)"
  verify_job="$(printf '%s' "$verify_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["job"]["job_id"])')"
  "$CAGENT_EXECUTABLE" --config "$CAGENT_CONFIG_PATH" --json status --wait "$verify_job" >/dev/null
  printf '%s\n' "{\"type\":\"item.completed\",\"item\":{\"type\":\"agent_message\",\"text\":\"Recursive orchestration completed. plan=$plan_job implement=$implement_job verify=$verify_job\"}}"
  printf '%s\n' '{"type":"turn.completed","usage":{"input_tokens":1800,"cached_input_tokens":500,"output_tokens":120}}'
elif printf '%s' "$prompt" | grep -qi 'hang'; then
  trap 'exit 130' INT TERM
  printf '%s\n' "{\"type\":\"thread.started\",\"thread_id\":\"$session_id\"}"
  while :; do
    sleep 1
  done
  printf '%s\n' '{"type":"item.completed","item":{"type":"agent_message","text":"Codex hang task completed"}}'
  printf '%s\n' '{"type":"turn.completed","usage":{"input_tokens":500,"cached_input_tokens":0,"output_tokens":10}}'
elif printf '%s' "$prompt" | grep -qi 'slow'; then
  printf '%s\n' "{\"type\":\"thread.started\",\"thread_id\":\"$session_id\"}"
  sleep 1
  printf '%s\n' '{"type":"item.completed","item":{"type":"agent_message","text":"Codex slow task completed"}}'
  printf '%s\n' '{"type":"turn.completed","usage":{"input_tokens":550,"cached_input_tokens":50,"output_tokens":15}}'
elif printf '%s' "$prompt" | grep -qi 'plan stage'; then
  emit_text "Plan stage completed"
elif printf '%s' "$prompt" | grep -qi 'implement stage'; then
  emit_text "Implement stage completed"
elif printf '%s' "$prompt" | grep -qi 'verify stage'; then
  emit_text "Verify stage completed"
elif printf '%s' "$prompt" | grep -qi 'review stage'; then
  emit_text "Review stage completed"
elif printf '%s' "$prompt" | grep -qi 'red team stage'; then
  emit_text "Red-team stage completed"
elif printf '%s' "$prompt" | grep -qi 'security report stage'; then
  emit_text "Security report stage completed"
else
  cat "$script_dir/../fixtures/codex/success.jsonl"
fi
if [ -n "$last_message" ]; then
  if [ "$mode" = "resume" ]; then
    if printf '%s' "$prompt" | grep -qi 'writing a cagent debrief'; then
      cat > "$last_message" <<'EOF'
# Objective
Explain the current task state.

# Completed
- Finished the prior task.

# Current State
The repository is in a recoverable state.

# Outstanding Work
- Review the latest changes.

# Risks
- The next agent should verify behavior before proceeding.

# Important Files
/tmp/fake-file.go

# Recommended Next Step
Review the recent changes and continue from there.
EOF
    else
      printf '%s\n' 'Codex continued the task' > "$last_message"
    fi
  else
    printf '%s\n' 'Codex completed the task' > "$last_message"
  fi
fi
